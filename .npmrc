# @cloudflare/next-on-pages@1 has contradictory peers: it wants
# @cloudflare/workers-types@^4, while the wrangler@4 it pulls in wants ^5.
# npm then fails the build with ERESOLVE. These are peerOptional *type*
# packages, so a mismatch is harmless. Do not remove without testing a deploy.
legacy-peer-deps=true
